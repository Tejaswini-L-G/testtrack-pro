generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String              @id @default(uuid())
  name             String
  email            String              @unique
  password         String
  role             String              @default("tester")
  createdAt        DateTime            @default(now())
  resetExpiry      DateTime?
  resetToken       String?
  failedAttempts   Int                 @default(0)
  isVerified       Boolean             @default(false)
  lockUntil        DateTime?
  passwordHistory  String[]
  refreshToken     String?
  verifyToken      String?
  attachments      Attachment[]
  testCases        TestCase[]
  TestCaseTemplate TestCaseTemplate[]
  testSuites       TestSuite[]
  assignments      TestRunAssignment[]

  reportedBugs  Bug[] 
}

model TestCase {
  id            String  @id @default(uuid())
  testCaseId    String  @unique
  title         String
  description   String
  module        String
  priority      String
  severity      String
  type          String
  status        String
  preconditions String?

  impactIfFails String?

  testDataRequirements String?

  testData         String?
  environment      String?
  postconditions   String?
  cleanupSteps     String?
  createdById      String
  assignedTesterId String?
  version          Int      @default(1)
  tags             String[] @default([])
  isDeleted        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  attachments Attachment[]
  createdBy   User         @relation(fields: [createdById], references: [id])

  versions TestCaseVersion[]
  steps    TestStep[]

  suiteId String?
  suite   TestSuite? @relation(fields: [suiteId], references: [id])
}

model TestStep {
  id          String       @id @default(uuid())
  testCaseId  String
  stepNumber  Int
  action      String
  testData    String?
  expected    String
  attachments Attachment[]
  testCase    TestCase     @relation(fields: [testCaseId], references: [id])
}

model Attachment {
  id           String    @id @default(uuid())
  fileName     String
  fileType     String
  filePath     String
  testCaseId   String?
  testStepId   String?
  uploadedById String
  isDeleted    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  testCase     TestCase? @relation(fields: [testCaseId], references: [id])
  testStep     TestStep? @relation(fields: [testStepId], references: [id])
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])
}

model TestCaseVersion {
  id         String   @id @default(uuid())
  testCaseId String
  version    Int
  changeLog  String
  snapshot   Json
  createdAt  DateTime @default(now())
  testCase   TestCase @relation(fields: [testCaseId], references: [id])
}

model TestSuite {
  id          String     @id @default(uuid())
  name        String
  description String?
  createdById String
  createdBy   User       @relation(fields: [createdById], references: [id])
  testCases   TestCase[]
  createdAt   DateTime   @default(now())

  isDeleted Boolean @default(false)
}

model TestCaseTemplate {
  id          String         @id @default(uuid())
  name        String
  description String?
  module      String
  priority    String
  severity    String
  type        String
  createdById String
  createdAt   DateTime       @default(now())
  steps       TemplateStep[]
  createdBy   User           @relation(fields: [createdById], references: [id])

  category String @default("General")

  isGlobal Boolean @default(true) // ⭐ org-wide
}

model TemplateStep {
  id         String           @id @default(uuid())
  templateId String
  stepNumber Int
  action     String
  testData   String?
  expected   String
  template   TestCaseTemplate @relation(fields: [templateId], references: [id])
}

model TestExecution {
  id           String    @id @default(uuid())
  testCaseId   String
  executedById String
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  status       String // InProgress / Passed / Failed

  steps ExecutionStep[]

  testRunId    String?
  testRun   TestRun? @relation(fields: [testRunId], references: [id])
}

model ExecutionStep {
  id          String @id @default(uuid())
  executionId String
  stepNumber  Int
  action      String
  expected    String

  actual String?
  status String? // Pass / Fail / Blocked / Skipped
  notes  String?

  execution TestExecution @relation(fields: [executionId], references: [id])
}

model ExecutionEvidence {
  id         String   @id @default(uuid())
  testCaseId String
  stepNumber Int
  filePath   String
  fileType   String
  uploadedAt DateTime @default(now())
}

model ExecutionResult {
  id            String   @id @default(uuid())
  testCaseId    String
  executionTime Int? // ⏱ total time in seconds
  completedAt   DateTime @default(now())
}

model TestRun {
  id          String   @id @default(uuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      String   @default("Planned")
  createdAt   DateTime @default(now())

  testCases     TestRunCase[]
  assignments   TestRunAssignment[]
  TestExecution TestExecution[]
}

model TestRunCase {
  id         String @id @default(uuid())
  testRunId  String
  testCaseId String

  testRun TestRun @relation(fields: [testRunId], references: [id])
}

model TestRunAssignment {
  id        String @id @default(uuid())
  testRunId String
  testerId  String

  testRun TestRun @relation(fields: [testRunId], references: [id])
  tester  User    @relation(fields: [testerId], references: [id])
}


model Bug {
  id            String   @id @default(uuid())
  title         String
  description   String
  severity      String
  priority      String
  status        String   @default("Open")

  testCaseId    String?
  runId         String?
  stepNumber    Int?

  evidencePath  String?   // ⭐ NEW

  createdAt     DateTime @default(now())
  createdById String?
  reportedById String?
  reportedBy   User?  @relation(fields: [reportedById], references: [id])
}