generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String              @id @default(uuid())
  name             String
  email            String              @unique
  password         String
  role             String              @default("tester")
  createdAt        DateTime            @default(now())
  resetExpiry      DateTime?
  resetToken       String?
  failedAttempts   Int                 @default(0)
  isVerified       Boolean             @default(false)
  lockUntil        DateTime?
  passwordHistory  String[]
  refreshToken     String?
  verifyToken      String?
  attachments      Attachment[]
  testCases        TestCase[]
  TestCaseTemplate TestCaseTemplate[]
  testSuites       TestSuite[]
  assignments      TestRunAssignment[]

  reportedBugs  Bug[]
  TestExecution TestExecution[]
  assignedBugs  Bug[]           @relation("AssignedBugs")

  bugComments BugComment[]
  active      Boolean      @default(true)

  Role            Role?             @relation(fields: [roleId], references: [id])
  roleId          String?
  DashboardWidget DashboardWidget[]
  Project         Project[]
  AuditLog        AuditLog[]
  projects        ProjectMember[]
  FilterPreset    FilterPreset[]
  notifications Notification[]
preference    NotificationPreference?
}

model TestCase {
  id            String  @id @default(uuid())
  testCaseId    String  @unique
  title         String
  description   String
  module        String
  priority      String
  severity      String
  type          String
  status        String
  preconditions String?

  impactIfFails String?

  testDataRequirements String?

  testData         String?
  environment      String?
  postconditions   String?
  cleanupSteps     String?
  createdById      String
  assignedTesterId String?
  version          Int      @default(1)
  tags             String[] @default([])
  isDeleted        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  attachments Attachment[]
  createdBy   User         @relation(fields: [createdById], references: [id])

  versions TestCaseVersion[]
  steps    TestStep[]

  suiteId             String?
  suite               TestSuite?            @relation(fields: [suiteId], references: [id])
  order               Int?
  projectId           String
  project             Project               @relation(fields: [projectId], references: [id])
  TestCaseCustomValue TestCaseCustomValue[]
}

model TestStep {
  id          String       @id @default(uuid())
  testCaseId  String
  stepNumber  Int
  action      String
  testData    String?
  expected    String
  attachments Attachment[]
  testCase    TestCase     @relation(fields: [testCaseId], references: [id])
}

model Attachment {
  id           String    @id @default(uuid())
  fileName     String
  fileType     String
  filePath     String
  testCaseId   String?
  testStepId   String?
  uploadedById String
  isDeleted    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  testCase     TestCase? @relation(fields: [testCaseId], references: [id])
  testStep     TestStep? @relation(fields: [testStepId], references: [id])
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])
}

model TestCaseVersion {
  id         String   @id @default(uuid())
  testCaseId String
  version    Int
  changeLog  String
  snapshot   Json
  createdAt  DateTime @default(now())
  testCase   TestCase @relation(fields: [testCaseId], references: [id])
}

model TestSuite {
  id          String   @id @default(uuid())
  name        String
  description String?
  module      String?
  parentId    String?
  createdById String
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())

  parent   TestSuite?  @relation("SuiteHierarchy", fields: [parentId], references: [id])
  children TestSuite[] @relation("SuiteHierarchy")

  createdBy User       @relation(fields: [createdById], references: [id])
  testCases TestCase[]

  isDeleted Boolean @default(false)
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
}

model TestCaseTemplate {
  id          String         @id @default(uuid())
  name        String
  description String?
  module      String
  priority    String
  severity    String
  type        String
  createdById String
  createdAt   DateTime       @default(now())
  steps       TemplateStep[]
  createdBy   User           @relation(fields: [createdById], references: [id])

  category String @default("General")

  isGlobal Boolean @default(true) // ⭐ org-wide
}

model TemplateStep {
  id         String           @id @default(uuid())
  templateId String
  stepNumber Int
  action     String
  testData   String?
  expected   String
  template   TestCaseTemplate @relation(fields: [templateId], references: [id])
}

model TestExecution {
  id           String    @id @default(uuid())
  testCaseId   String
  executedById String
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  status       String // InProgress / Passed / Failed

  steps ExecutionStep[]

  testRunId String?
  testRun   TestRun? @relation(fields: [testRunId], references: [id])

  executedBy User @relation(fields: [executedById], references: [id])
}

model ExecutionStep {
  id          String @id @default(uuid())
  executionId String
  stepNumber  Int
  action      String
  expected    String

  actual String?
  status String? // Pass / Fail / Blocked / Skipped
  notes  String?

  execution TestExecution @relation(fields: [executionId], references: [id])

  @@unique([executionId, stepNumber])
}

model ExecutionEvidence {
  id         String   @id @default(uuid())
  testCaseId String
  stepNumber Int
  filePath   String
  fileType   String
  uploadedAt DateTime @default(now())
}

model ExecutionResult {
  id            String   @id @default(uuid())
  testCaseId    String
  executionTime Int? // ⏱ total time in seconds
  completedAt   DateTime @default(now())
}

model TestRun {
  id          String   @id @default(uuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      String   @default("Planned")
  createdAt   DateTime @default(now())

  testCases     TestRunCase[]
  assignments   TestRunAssignment[]
  TestExecution TestExecution[]
  projectId     String
  project       Project             @relation(fields: [projectId], references: [id])
  milestoneId   String?
  milestone     ProjectMilestone?   @relation(fields: [milestoneId], references: [id])
}

model TestRunCase {
  id         String @id @default(uuid())
  testRunId  String
  testCaseId String

  testRun TestRun @relation(fields: [testRunId], references: [id])
}

model TestRunAssignment {
  id        String @id @default(uuid())
  testRunId String
  testerId  String

  testRun TestRun @relation(fields: [testRunId], references: [id])
  tester  User    @relation(fields: [testerId], references: [id])
}

model Bug {
  id          String @id @default(uuid())
  title       String
  description String
  severity    String
  priority    String
  status      String @default("Open")

  testCaseId String?
  runId      String?
  stepNumber Int?

  evidencePath String? // ⭐ NEW

  createdAt    DateTime @default(now())
  createdById  String?
  reportedById String?
  reportedBy   User?    @relation(fields: [reportedById], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("AssignedBugs", fields: [assignedToId], references: [id])

  bugId String? @unique // Human-readable ID (BUG-2026-0001)

  stepsToReproduce String? // Exact reproduction steps
  expectedBehavior String? // What should happen
  actualBehavior   String? // What actually happened

  environment     String? // Browser / OS / env
  affectedVersion String? // App version
  type            String?

  fixNotes       String?
  commitLink     String?
  resolutionNote String?
  fixedAt        DateTime?
  startedAt      DateTime?

  comments  BugComment[]
  projectId String
  project   Project      @relation(fields: [projectId], references: [id])
}

model BugComment {
  id       String   @id @default(uuid())
  content  String
  bugId    String
  authorId String
  parentId String?
  mentions String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bug    Bug  @relation(fields: [bugId], references: [id])
  author User @relation(fields: [authorId], references: [id])

  parent  BugComment?  @relation("Thread", fields: [parentId], references: [id])
  replies BugComment[] @relation("Thread")
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  permissions Permission[]
  users       User[]
}

model Permission {
  id     String @id @default(uuid())
  name   String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])
}

model DashboardWidget {
  id        String   @id @default(uuid())
  userId    String
  type      String // chart / list / counter / table
  title     String
  position  Int
  config    Json?
  createdAt DateTime @default(now())
  projectId String?
  width     Int      @default(1)

  user User @relation(fields: [userId], references: [id])
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  active      Boolean  @default(true)

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  testCases          TestCase[]
  testSuites         TestSuite[]
  testRuns           TestRun[]
  bugs               Bug[]
  members            ProjectMember[]
  ProjectCustomField ProjectCustomField[]
  ProjectWorkflow    ProjectWorkflow[]
  ProjectModule      ProjectModule[]
  ProjectEnvironment ProjectEnvironment[]
  ProjectMilestone   ProjectMilestone[]
}

model AuditLog {
  id       String  @id @default(uuid())
  userId   String
  action   String
  entity   String
  entityId String?
  details  String?

  createdAt DateTime @default(now())

  user       User?   @relation(fields: [userId], references: [id])
  isArchived Boolean @default(false)
}

model SystemConfig {
  id              String   @id @default(uuid())
  defaultSeverity String?
  defaultPriority String?
  emailEnabled    Boolean  @default(true)
  autoAssignBug   Boolean  @default(false)
  maxUploadSize   Int      @default(10) // in MB
  updatedAt       DateTime @updatedAt
}

model ProjectMember {
  id String @id @default(uuid())

  userId    String
  projectId String

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  role String? // optional: project-level role

  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

model ProjectCustomField {
  id       String  @id @default(uuid())
  name     String
  type     String // text, select, number, date
  required Boolean @default(false)
  options  String? // JSON string for dropdown options

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  createdAt           DateTime              @default(now())
  TestCaseCustomValue TestCaseCustomValue[]
}

model TestCaseCustomValue {
  id    String @id @default(uuid())
  value String

  testCaseId String
  testCase   TestCase @relation(fields: [testCaseId], references: [id])

  fieldId String
  field   ProjectCustomField @relation(fields: [fieldId], references: [id])
}

model ProjectWorkflow {
  id        String  @id @default(uuid())
  name      String // Bug or TestCase
  statuses  String // JSON array
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
}

model ProjectModule {
  id        String  @id @default(uuid())
  name      String
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
}

model ProjectEnvironment {
  id        String   @id @default(uuid())
  name      String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())
}

model ProjectMilestone {
  id             String   @id @default(uuid())
  name           String
  description    String?
  targetDate     DateTime
  targetPassRate Float
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id])
  createdAt      DateTime @default(now())

  testRuns TestRun[]
}

model FilterPreset {
  id        String   @id @default(uuid())
  name      String
  userId    String
  filters   Json
  isShared  Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}





model Notification {
  id        String   @id @default(uuid())
  type      String   // BUG_ASSIGNED, STATUS_CHANGED, COMMENT, etc
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  userId    String
  referenceId String?
}

model NotificationPreference {
  id      String @id @default(uuid())
  user    User   @relation(fields: [userId], references: [id])
  userId  String @unique

  bugAssignedEmail     Boolean @default(true)
  bugAssignedInApp     Boolean @default(true)

  statusChangedEmail   Boolean @default(true)
  statusChangedInApp   Boolean @default(true)

  commentEmail         Boolean @default(false)
  commentInApp         Boolean @default(true)

  testAssignedEmail    Boolean @default(true)
  testAssignedInApp    Boolean @default(true)

  retestEmail          Boolean @default(true)
  retestInApp          Boolean @default(true)

  quietHoursStart      String?
  quietHoursEnd        String?
}